if [[ $SKIP_HOOKS -gt 0 ]]; then
  echo "[PRE-COMMIT] skipping hooks (SKIP_HOOKS=$SKIP_HOOKS)"
  exit 0
fi

# ── Regenerate dist files when source data or URL rules change ────────────────
# Paths are relative to this repo root (ssjs-data/).
STAGED=$(git diff --cached --name-only)

NEEDS_REGEN=false
for f in $STAGED; do
  case "$f" in
    src/index.js|src/urls.js)
      NEEDS_REGEN=true
      break
      ;;
  esac
done

if [ "$NEEDS_REGEN" = true ]; then
  echo "[PRE-COMMIT] 🔄 ssjs-data source changed — regenerating dist files..."
  npm run generate:all --no-workspaces || {
    echo "[PRE-COMMIT] ❌ generate:all failed. Fix the errors above and try again."
    exit 1
  }
  git add dist/sfmc-globals.d.ts dist/site-index.json
  echo "[PRE-COMMIT] ✅ dist files regenerated and staged."
fi

# ── Lint & test ───────────────────────────────────────────────────────────────
echo "[PRE-COMMIT] Run lint-staged"
npx lint-staged || {
  echo "[PRE-COMMIT] lint-staged reported errors it could not auto-fix. Fix them manually and try again."
  exit 1
}

echo "[PRE-COMMIT] Running tests..."
npm test --no-workspaces || {
  echo "[PRE-COMMIT] Tests failed. Fix the errors above and try again."
  exit 1
}

echo "[PRE-COMMIT] All checks passed."
